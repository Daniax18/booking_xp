# Log Service Environment Variables
# ---
# 📚 Chaque service a son propre .env (Database per Service)
# ---

SERVICE_NAME=log-service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8005
DEBUG=True

# Base de données PROPRE au log-service
DATABASE_URL=postgresql+asyncpg://log_user:log_password@log-db:5432/log_db
DATABASE_ECHO=False

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# CORS
CORS_ORIGINS=*
